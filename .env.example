# ── Copy this to .env and fill in your values ──────────────────────────────

# App
APP_ENV=production
APP_SECRET_KEY=change-me-to-a-long-random-string-min-32-chars

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_WEBHOOK_URL=https://ai-trading-vlidator.onrender.com/webhook/telegram

# Database (Render PostgreSQL — copy from Render dashboard)
DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname

# Redis (Render Redis — copy from Render dashboard)
REDIS_URL=redis://localhost:6379/0

# DeepSeek AI
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Whop Payments
WHOP_API_KEY=your-whop-api-key
WHOP_WEBHOOK_SECRET=your-whop-webhook-secret
WHOP_PRODUCT_ID_PRODUCT1=prod_xxxx
WHOP_PRODUCT_ID_PRODUCT2=prod_xxxx
WHOP_PRODUCT_ID_PRODUCT3=prod_xxxx
WHOP_PRODUCT_ID_PRO=prod_xxxx
WHOP_PRODUCT1_URL=https://whop.com/checkout/xxxx
WHOP_PRODUCT2_URL=https://whop.com/checkout/xxxx
WHOP_PRODUCT3_URL=https://whop.com/checkout/xxxx
WHOP_PRO_URL=https://whop.com/checkout/xxxx
WHOP_AFFILIATE_URL=https://whop.com/affiliate/xxxx

# RAGFlow (optional)
RAGFLOW_BASE_URL=http://localhost:9380
RAGFLOW_API_KEY=your-ragflow-key

# Public URLs
API_BASE_URL=https://ai-trading-vlidator.onrender.com
MINIAPP_BASE_URL=https://ai-trading-vlidator.onrender.com/app

# Bot download URLs
MT4_DOWNLOAD_URL=https://ai-trading-vlidator.onrender.com/api/download/ATV_Analyzer.mq4
MT5_DOWNLOAD_URL=https://ai-trading-vlidator.onrender.com/api/download/ATV_Analyzer.mq5
CTRADER_DOWNLOAD_URL=https://ai-trading-vlidator.onrender.com/api/download/ATV_Analyzer.cs

# Polygon.io (optional)
POLYGON_API_KEY=your-polygon-api-key

# DeepSeek cost tracking (optional)
DEEPSEEK_COST_PER_GEN=0.002

# Docker-specific
POSTGRES_USER=trader
POSTGRES_PASSWORD=trader_pass
POSTGRES_DB=tradevalidator
