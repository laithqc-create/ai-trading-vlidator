# ── Copy this to .env and fill in your values ──────────────────────────────

# App
APP_ENV=development
APP_SECRET_KEY=change-me-to-random-string

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/telegram

# Database (matches docker-compose defaults)
DATABASE_URL=postgresql+asyncpg://trader:trader_pass@localhost:5432/tradevalidator
REDIS_URL=redis://localhost:6379/0

# DeepSeek AI (code gen + OHLC analysis + chat)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Whop Payments
WHOP_API_KEY=your-whop-api-key
WHOP_WEBHOOK_SECRET=your-whop-webhook-secret
WHOP_PRODUCT_ID_PRODUCT1=prod_xxxx   # $19/mo Indicator Validator
WHOP_PRODUCT_ID_PRODUCT2=prod_xxxx   # $49/mo EA Analyzer
WHOP_PRODUCT_ID_PRODUCT3=prod_xxxx   # $29/mo Live Analysis
WHOP_PRODUCT_ID_PRO=prod_xxxx        # $79/mo Pro Bundle

# Whop Checkout URLs (used by Mini App + Extension upgrade buttons)
WHOP_PRODUCT1_URL=https://whop.com/checkout/xxxx
WHOP_PRODUCT2_URL=https://whop.com/checkout/xxxx
WHOP_PRODUCT3_URL=https://whop.com/checkout/xxxx
WHOP_PRO_URL=https://whop.com/checkout/xxxx
WHOP_AFFILIATE_URL=https://whop.com/affiliate/xxxx

# RAGFlow (optional — needed for personal rules KB)
RAGFLOW_BASE_URL=http://localhost:9380
RAGFLOW_API_KEY=your-ragflow-key

# MT4/MT5 bot download URLs (hosted files)
MT4_DOWNLOAD_URL=https://your-domain.com/bots/ATV_Analyzer.mq4
MT5_DOWNLOAD_URL=https://your-domain.com/bots/ATV_Analyzer.mq5

# Polygon.io (optional — used for live market data in Product 1 validation)
POLYGON_API_KEY=your-polygon-api-key

# cTrader cBot download URL
CTRADER_DOWNLOAD_URL=https://your-domain.com/bots/ATV_Analyzer.cs

# Public URLs (used by serve.py to inject API_BASE into the Mini App)
API_BASE_URL=https://api.aitradevalidator.com
MINIAPP_BASE_URL=https://api.aitradevalidator.com/app

# DeepSeek cost tracking (optional — for usage monitoring)
DEEPSEEK_COST_PER_GEN=0.002

# Docker-specific (used by docker-compose.yml)
POSTGRES_USER=trader
POSTGRES_PASSWORD=trader_pass
POSTGRES_DB=tradevalidator
