# ─── Telegram ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/telegram

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://trader:trader_pass@localhost:5432/tradevalidator
REDIS_URL=redis://localhost:6379/0

# ─── OpenTrade.ai (LLM Provider) ───────────────────────────
# Options: ollama | lmstudio | openai
LLM_PROVIDER=ollama
LLM_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234/v1
OPENAI_API_KEY=

# ─── RAGFlow ───────────────────────────────────────────────
RAGFLOW_BASE_URL=http://localhost:9380
RAGFLOW_API_KEY=your_ragflow_api_key
RAGFLOW_SYSTEM_KB_ID=system_knowledge_base_id
# Each user gets their own dataset — prefix for auto-created datasets
RAGFLOW_USER_KB_PREFIX=user_

# ─── Market Data ───────────────────────────────────────────
# Polygon.io for Product 3 (Manual Validator)
POLYGON_API_KEY=your_polygon_api_key_here

# ─── Stripe Payments ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRODUCT1=price_...   # $29/mo Indicator Validator
STRIPE_PRICE_PRODUCT2=price_...   # $49/mo EA Analyzer
STRIPE_PRICE_PRODUCT3=price_...   # $19/mo Manual Validator
STRIPE_PRICE_PRO=price_...        # $79/mo All Products

# ─── App Settings ──────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change_this_to_a_random_secret
FREE_TIER_DAILY_LIMIT=5
LOG_LEVEL=INFO

# ─── Optional: Webhook security ────────────────────────────
INDICATOR_WEBHOOK_SECRET=random_secret_for_indicator_webhooks
EA_WEBHOOK_SECRET=random_secret_for_ea_webhooks
