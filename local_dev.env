# ══════════════════════════════════════════════════
#  AI Trade Validator — Local Dev
#  3-CMD setup:
#    CMD 1: cloudflared.exe tunnel --url http://localhost:8000
#    CMD 2: uvicorn main:app --port 8000
#    CMD 3: python TG_Bot/main.py
#
#  After CMD 1 starts, copy the https://xxx.trycloudflare.com
#  URL and update CLOUDFLARE_URL + TELEGRAM_WEBHOOK_URL below.
#  Then restart CMD 2 and CMD 3.
# ══════════════════════════════════════════════════

# ── Your keys (fill these in) ──────────────────────
TELEGRAM_BOT_TOKEN=PASTE_YOUR_TOKEN_HERE
DEEPSEEK_API_KEY=PASTE_YOUR_DEEPSEEK_KEY_HERE

# ── Cloudflare tunnel URL ──────────────────────────
# Step 1: run cloudflared.exe tunnel --url http://localhost:8000
# Step 2: copy the https://xxxx.trycloudflare.com URL shown
# Step 3: paste it below (no trailing slash)
CLOUDFLARE_URL=https://PASTE-YOUR-CLOUDFLARE-URL-HERE.trycloudflare.com

# These are derived from CLOUDFLARE_URL — keep them in sync
API_BASE_URL=https://PASTE-YOUR-CLOUDFLARE-URL-HERE.trycloudflare.com
MINIAPP_BASE_URL=https://PASTE-YOUR-CLOUDFLARE-URL-HERE.trycloudflare.com/app
TELEGRAM_WEBHOOK_URL=https://PASTE-YOUR-CLOUDFLARE-URL-HERE.trycloudflare.com/webhook/telegram

# ── Database (SQLite, zero install) ───────────────
DATABASE_URL=sqlite+aiosqlite:///./local_dev.db

# ── Redis / Celery (not needed — tasks run inline) ─
REDIS_URL=redis://localhost:6379/0

# ── App ────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=local-dev-secret

# ── DeepSeek ───────────────────────────────────────
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_COST_PER_GEN=0.002

# ── Whop (placeholder for local testing) ──────────
WHOP_PRODUCT1_URL=https://whop.com
WHOP_PRODUCT2_URL=https://whop.com
WHOP_PRODUCT3_URL=https://whop.com
WHOP_PRO_URL=https://whop.com
WHOP_AFFILIATE_URL=https://whop.com
WHOP_WEBHOOK_SECRET=
WHOP_API_KEY=

# ── Polygon (optional) ─────────────────────────────
POLYGON_API_KEY=

# ── Bot download URLs ──────────────────────────────
MT4_DOWNLOAD_URL=https://PASTE-YOUR-CLOUDFLARE-URL-HERE.trycloudflare.com/api/download/ATV_Analyzer.mq4
MT5_DOWNLOAD_URL=https://PASTE-YOUR-CLOUDFLARE-URL-HERE.trycloudflare.com/api/download/ATV_Analyzer.mq5
CTRADER_DOWNLOAD_URL=https://PASTE-YOUR-CLOUDFLARE-URL-HERE.trycloudflare.com/api/download/ATV_Analyzer.cs
