# ── Render production config ─────────────────────────────────────────────────
# This file is loaded by main.py on startup (override=False, so Render
# dashboard env vars always win over these defaults).

TELEGRAM_BOT_TOKEN=SET_VIA_RENDER_DASHBOARD
DEEPSEEK_API_KEY=SET_VIA_RENDER_DASHBOARD
API_BASE_URL=https://ai-trading-vlidator.onrender.com
MINIAPP_BASE_URL=https://ai-trading-vlidator.onrender.com/app
TELEGRAM_WEBHOOK_URL=https://ai-trading-vlidator.onrender.com/webhook/telegram

# Database — set via Render dashboard (these are SQLite fallbacks for local use only)
DATABASE_URL=sqlite+aiosqlite:///./local_dev.db
REDIS_URL=redis://localhost:6379/0

APP_ENV=production
APP_SECRET_KEY=local-dev-secret-change-in-render-dashboard

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_COST_PER_GEN=0.002

# Whop — fill in once you create products on Whop
WHOP_PRODUCT1_URL=https://whop.com
WHOP_PRODUCT2_URL=https://whop.com
WHOP_PRODUCT3_URL=https://whop.com
WHOP_PRO_URL=https://whop.com
WHOP_AFFILIATE_URL=https://whop.com
WHOP_WEBHOOK_SECRET=
WHOP_API_KEY=

# Download URLs
MT4_DOWNLOAD_URL=https://ai-trading-vlidator.onrender.com/api/download/ATV_Analyzer.mq4
MT5_DOWNLOAD_URL=https://ai-trading-vlidator.onrender.com/api/download/ATV_Analyzer.mq5
CTRADER_DOWNLOAD_URL=https://ai-trading-vlidator.onrender.com/api/download/ATV_Analyzer.cs

POLYGON_API_KEY=
